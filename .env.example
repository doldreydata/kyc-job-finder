# Adzuna API (free, 1,000 calls/month) — https://developer.adzuna.com/signup
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter model — using DeepSeek V4 Flash
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# --- SMTP (optional — leave SMTP_PASS blank to skip email and just print results) ---

# ProtonMail: use an App Password from ProtonMail settings
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USER=you@protonmail.com
# Leave blank to skip emails
SMTP_PASS=

# Gmail: use an App Password from Google Account settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_gmail_app_password

# Where to send the job alert (not needed if SMTP is blank)
EMAIL_TO=

# ntfy.sh push notifications (free, no account needed)
# 1. Install the "ntfy" app on your phone (iOS/Android)
# 2. Pick a unique topic name (e.g. "kyc-jobs-abc123")
# 3. Put it here:
NTFY_TOPIC=

# Comma-separated search queries
SEARCH_QUERIES=KYC analyst, AML analyst, financial crime analyst, customer due diligence, KYC onboarding

# Job-hunt location (city, country, or "Remote")
LOCATION=United Kingdom

# Minimum score to include in email (0-100)
MIN_SCORE=70

# Max jobs to rate per run (cost control)
MAX_JOBS_PER_RUN=40

# Path to your CV PDF
CV_PATH=cv.pdf